# LangChain
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=false
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_PROJECT=omnisummary

# Logging
LOG_LEVEL=INFO

# Slack
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=            # Socket Mode — only for local slack_agent.py
SLACK_CHANNEL_ID=
SLACK_SIGNING_SECRET=      # only for the AWS Slack-events API Gateway path

# Tavily (web search)
TAVILY_API_KEY=

# YouTube (optional; without it: RSS fallback, no transcripts)
YOUTUBE_API_KEY=

# OpenAI (optional; enables daily visual + agent make_visual)
OPENAI_API_KEY=

# Threads delivery (optional; 60-day token auto-refreshed to SSM in AWS)
THREADS_ACCESS_TOKEN=
THREADS_USER_ID=

# X/Twitter via RSSHub — x.com session cookies (see README "RSSHub Container")
TWITTER_AUTH_TOKEN=
TWITTER_CT0=

# Alerting (optional; source-health SNS email)
ALERT_EMAIL=

# Cloudflare proxy (Reddit .rss / YouTube from AWS IPs)
CLOUDFLARE_PROXY_URL=
CLOUDFLARE_PROXY_TOKEN=

# AWS
AWS_PROFILE_NAME=

# Local -> S3 sync (scripts/sync_*_to_s3.py); optional, falls back to AWS_PROFILE
S3_SYNC_ACCESS_KEY_ID=
S3_SYNC_SECRET_ACCESS_KEY=
